          "data": {
            "content": {
              "en": "<h1>Terms and Conditions</h1><p>By using this site you agree to our terms of use. Please read them carefully before placing an order.</p><p>XMart Store reserves the right to modify these terms at any time. Continued use of the site constitutes acceptance of the updated terms.</p>"
            }
          }
