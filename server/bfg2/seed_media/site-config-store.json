    {
      "slug": "about",
      "title": "About Us",
      "language": "en",
      "status": "published",
      "order": 20,
      "meta_title": "About Us - XMart Store",
      "meta_description": "Learn more about XMart fashion store.",
      "blocks": [
        {
          "id": "about-content",
          "type": "text_block_v1",
          "settings": {
            "align": "left",
            "maxWidth": "800px"
          },
          "data": {
            "content": {
              "en": "<h1>About Us</h1><p>Welcome to XMart Store, your destination for the latest fashion trends. We offer a curated selection of clothing, shoes, bags, watches and accessories for men and women.</p><p>Our mission is to make fashion accessible and enjoyable for everyone. We source quality products from trusted suppliers around the world.</p>"
            }
          }
        }
      ]
    },
    {
      "slug": "contact",
      "title": "Contact Us",
      "language": "en",
      "status": "published",
      "order": 21,
      "meta_title": "Contact Us - XMart Store",
      "meta_description": "Get in touch with the XMart Store team.",
      "blocks": [
        {
          "id": "contact-content",
          "type": "text_block_v1",
          "settings": {
            "align": "left",
            "maxWidth": "800px"
          },
          "data": {
            "content": {
              "en": "<h1>Contact Us</h1><p>Have questions? We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p><p>Email: support@XMart.com</p><p>Phone: +1 (555) 000-0000</p><p>Hours: Monday – Friday, 9am – 6pm EST</p>"
            }
          }
        }
      ]
    },
    {
      "slug": "delivery",
      "title": "Delivery",
      "language": "en",
      "status": "published",
      "order": 30,
      "meta_title": "Delivery Information - XMart Store",
      "meta_description": "Learn about our delivery options and shipping times.",
      "blocks": [
        {
          "id": "delivery-content",
          "type": "text_block_v1",
          "settings": {
            "align": "left",
            "maxWidth": "800px"
          },
          "data": {
            "content": {
              "en": "<h1>Delivery</h1><p>We offer reliable delivery options across the globe.</p><ul><li><strong>Standard Shipping:</strong> 3–5 business days</li><li><strong>Express Shipping:</strong> 1–2 business days</li><li><strong>Free shipping</strong> on orders over $75</li></ul><p>Orders placed before 2pm EST ship the same day. You will receive a tracking number by email once your order ships.</p>"
            }
          }
        }
      ]
    },
    {
      "slug": "legal-notice",
